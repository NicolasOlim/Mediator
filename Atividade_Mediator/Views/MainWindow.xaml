<Window x:Class="Atividade_Mediator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema Completo - Mediator + Persistência Automática" 
        Height="500" Width="650" 
        WindowStartupLocation="CenterScreen" 
        Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" Padding="15,10" Margin="0,0,0,15" CornerRadius="8">
            <StackPanel x:Name="PainelPesquisa" Orientation="Horizontal">
                <TextBlock Text="🔍 Buscar Cliente:" VerticalAlignment="Center" FontWeight="Bold" Foreground="#555" Margin="0,0,10,0"/>
                <TextBox Text="{Binding TermoPesquisa, UpdateSourceTrigger=PropertyChanged}" 
                         Width="450" Height="30" Padding="5,0" VerticalContentAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="White" Padding="20" Margin="0,0,10,15" CornerRadius="8">
            <StackPanel x:Name="PainelCadastro">
                <TextBlock Text="Gerenciar Cliente" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Label Content="Nome Completo:" Foreground="#666" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NomeCliente, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" Margin="0,5,0,20" Padding="5,0" VerticalContentAlignment="Center" FontSize="14"/>

                <Button Content="GUARDAR" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" Cursor="Hand" Click="BtnSalvar_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="EXCLUIR" Height="40" Background="#E74C3C" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnExcluir_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="White" Padding="20" Margin="10,0,0,15" CornerRadius="8">
            <StackPanel x:Name="PainelLista">
                <TextBlock Text="Clientes Guardados" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <ListBox ItemsSource="{Binding Clientes}" 
                         SelectedItem="{Binding ClienteSelecionado}" 
                         DisplayMemberPath="Nome" 
                         Height="230" Background="#FAFAFA" BorderBrush="#DDD" FontSize="14" Padding="5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2D2D30" Padding="10,15" CornerRadius="5">
            <StackPanel x:Name="PainelStatus" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Text="{Binding Mensagem}" Foreground="#EAEAEA" FontWeight="SemiBold" FontSize="13" Width="400"/>
                <TextBlock Foreground="#4CAF50" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right">
                    <Run Text="Total Registados: "/>
                    <Run Text="{Binding TotalClientes}"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>